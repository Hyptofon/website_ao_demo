---
import Layout from "@/layouts/Layout.astro";
import { Header } from "@/components/layout/Header";
import { InstituteHero } from "@/routes/institute/sections/InstituteHero";
import { GeneralInfo } from "@/routes/institute/sections/GeneralInfo";
import { Education } from "@/routes/institute/sections/Education";
import { StudentLife } from "@/routes/institute/sections/StudentLife";
import { ScientificActivity } from "@/routes/institute/sections/ScientificActivity";
import { InstituteLeadership } from "@/routes/institute/sections/InstituteLeadership";
import { Footer } from "@/components/layout/Footer";
---

<Layout
  title="Про інститут | Інститут ІТ та бізнесу НаУОА"
  description="Інститут інформаційних технологій та бізнесу — простір, де народжуються лідери цифрової ери. Технології, бізнес та інновації."
>
  <div class="overflow-hidden w-full min-h-screen flex justify-center bg-layout-bg">
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header client:load />
      <main id="main-content" class="w-full">
        <InstituteHero />
        <GeneralInfo />
        <Education client:visible />
        <StudentLife />
        <ScientificActivity client:visible />
        <InstituteLeadership client:visible />
        <Footer />
      </main>
    </div>
  </div>
</Layout>
