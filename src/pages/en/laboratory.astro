---
import Layout from "@/layouts/Layout.astro";
import { Header } from "@/components/layout/Header";
import { Hero } from "@/routes/laboratory/sections/Hero";
import { AboutLaboratory } from "@/routes/laboratory/sections/AboutLaboratory";
import { Leadership } from "@/routes/laboratory/sections/Leadership";
import { Gallery } from "@/routes/laboratory/sections/Gallery";
import { Footer } from "@/components/layout/Footer";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "en";
const t = getTranslations(locale);
---

<Layout
  title={t.meta.labTitle}
  description={t.meta.labDescription}
  locale={locale}
>
  <div
    class="overflow-hidden w-full min-h-screen flex justify-center bg-layout-bg"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header
        client:load
        headerPosition="absolute"
        locale={locale}
        currentPath={Astro.url.pathname}
      />
      <main id="main-content" class="w-full">
        <Hero client:load locale={locale} />
        <AboutLaboratory locale={locale} />
        <Leadership locale={locale} />
        <Gallery client:visible locale={locale} />
      </main>
      <Footer client:visible locale={locale} />
    </div>
  </div>
</Layout>
