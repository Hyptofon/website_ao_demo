---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonicalUrl?: string;
}

const {
	title = "ІТБ - Інститут інформаційних технологій та бізнесу",
	description = "Навчально-науковий інститут інформаційних технологій та бізнесу НаУОА. Інновації, лідерство та технології.",
	ogImage = "/images/Home/og-default.webp",
	canonicalUrl,
} = Astro.props;

const siteUrl = Astro.site?.toString()?.replace(/\/$/, '') ?? '';
const metadataBaseUrl = siteUrl || Astro.url.origin;
const toAbsoluteUrl = (value: string): string => new URL(value, `${metadataBaseUrl}/`).toString();
const currentUrl = toAbsoluteUrl(canonicalUrl ?? Astro.url.pathname);
const ogImageUrl = toAbsoluteUrl(ogImage);
---

<!doctype html>
<html lang="uk" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#0f1215" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.webp" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.webp" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={currentUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="uk_UA" />
		<meta property="og:site_name" content="Інститут ІТ та бізнесу НаУОА" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "EducationalOrganization",
			"name": "Інститут інформаційних технологій та бізнесу",
			"alternateName": "ІТБ НаУОА",
			"url": siteUrl,
			"logo": `${siteUrl}/favicon.svg`,
			"description": "Інститут інформаційних технологій та бізнесу Національного університету \"Острозька академія\"",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "вул. Семінарська, 2",
				"addressLocality": "Острог",
				"postalCode": "35800",
				"addressCountry": "UA"
			},
			"telephone": "+380678792526",
			"email": "press@oa.edu.ua",
			"parentOrganization": {
				"@type": "CollegeOrUniversity",
				"name": "Національний університет \"Острозька академія\"",
				"url": "https://www.oa.edu.ua"
			}
		})} />

		<script is:inline>
			/* Check intro state instantly before body parses to prevent flash */
			if (typeof window !== "undefined") {
				try { 
					if (!localStorage.getItem('itb_intro_seen')) { 
						document.documentElement.classList.add('intro-active'); 
					} 
				} catch(e) {}
			}
		</script>
	</head>
	<body class="antialiased">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[200] focus:top-4 focus:left-4 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:font-medium">Перейти до вмісту</a>
		<div id="site-wrapper">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		overflow-x: hidden;
	}

	body {
		background: var(--color-layout-bg);
	}

	/* Wow Appearance Animation Variables & Rules */
	html.intro-active body {
		background-color: #030712 !important; /* matches IntroAnimation */
		overflow: hidden;
	}
	html.intro-active #site-wrapper {
		opacity: 0;
		transform: scale(0.95) translateY(20px);
		filter: blur(10px);
		pointer-events: none;
	}
	
	html.intro-transitioning body {
		background-color: var(--color-layout-bg) !important;
		transition: background-color 1.5s ease-in-out;
		overflow: hidden;
	}
	html.intro-transitioning #site-wrapper {
		opacity: 1;
		transform: scale(1) translateY(0);
		filter: blur(0);
		pointer-events: auto;
		transition: opacity 1.5s cubic-bezier(0.22, 1, 0.36, 1), 
					transform 1.5s cubic-bezier(0.22, 1, 0.36, 1),
					filter 1.5s cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: 0.1s; /* Start alongside IntroAnimation fade */
	}
</style>
