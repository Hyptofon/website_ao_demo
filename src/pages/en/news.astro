---
import Layout from "@/layouts/Layout.astro";
import { Footer } from "@/components/layout/Footer";
import { Header } from "@/components/layout/Header";
import { NewsPage } from "@/routes/news/NewsPage";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "en";
const t = getTranslations(locale);
---

<Layout
  title={t.meta.newsTitle}
  description={t.meta.newsDescription}
  locale={locale}
>
  <div
    class="overflow-x-clip w-full min-h-screen flex justify-center bg-pure-white"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header
        client:load
        variant="light"
        locale={locale}
        currentPath={Astro.url.pathname}
      />
      <main id="main-content" class="w-full">
        <NewsPage client:visible locale={locale} />
      </main>
      <Footer client:visible locale={locale} />
    </div>
  </div>
</Layout>
