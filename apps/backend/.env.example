# ─── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Vector DB ────────────────────────────────────────────────────────────────
# For local Docker: use "localhost"
# For Qdrant Cloud: use "your-cluster-id.europe-west3-0.gcp.cloud.qdrant.io"
QDRANT_URL=localhost
QDRANT_API_KEY=

# ─── Analytics DB ─────────────────────────────────────────────────────────────
DB_PATH=./data/analytics.db

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000

# ─── Security ─────────────────────────────────────────────────────────────────
# Admin API token (required for /admin/* endpoints)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Max chat requests per 5 minutes per IP (default: 10)
RATE_LIMIT_PER_MIN=10

# ─── Logging ──────────────────────────────────────────────────────────────────
# Set to "debug" for verbose output (default: info)
LOG_LEVEL=info
