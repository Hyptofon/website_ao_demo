---
import Layout from "@/layouts/Layout.astro";
import { Header } from "@/components/layout/Header";
import { ContactsPage } from "@/routes/contacts/ContactsPage";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "en";
const t = getTranslations(locale);
---

<Layout
  title={t.meta.contactsTitle}
  description={t.meta.contactsDescription}
  locale={locale}
>
  <div
    class="overflow-hidden w-full min-h-screen flex justify-center bg-pure-white"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header
        client:load
        variant="light"
        locale={locale}
        currentPath={Astro.url.pathname}
      />
      <main id="main-content" class="w-full">
        <ContactsPage client:idle locale={locale} />
      </main>
    </div>
  </div>
</Layout>
