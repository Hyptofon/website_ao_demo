---
import { Footer } from "@/components/layout/Footer";
import { Header } from "@/components/layout/Header";
import Layout from "@/layouts/Layout.astro";
import { FBDegreePrograms } from "@/routes/departments/finance-business/sections/FBDegreePrograms";
import { FBEducationalPrograms } from "@/routes/departments/finance-business/sections/FBEducationalPrograms";
import { FBHeroWithAbout } from "@/routes/departments/finance-business/sections/FBHeroWithAbout";
import { FBLeadership } from "@/routes/departments/finance-business/sections/FBLeadership";
import { FBScientificActivity } from "@/routes/departments/finance-business/sections/FBScientificActivity";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "uk";
const t = getTranslations(locale);
---

<Layout
  title={t.meta.fbTitle}
  description={t.meta.fbDescription}
  ogImage="/images/Departments/dfb-hero.webp"
  locale={locale}
>
  <div
    class="overflow-hidden w-full min-h-screen flex justify-center bg-layout-bg"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header
        client:load
        headerPosition="absolute"
        locale={locale}
        currentPath={Astro.url.pathname}
      />
      <main id="main-content" class="w-full">
        <FBHeroWithAbout client:load locale={locale} />
        <div
          class="relative w-full translate-y-[-1rem] animate-fade-in opacity-0 [--animation-delay:600ms]"
        >
          <FBEducationalPrograms locale={locale} />
        </div>
        <FBDegreePrograms client:visible locale={locale} />
        <FBLeadership locale={locale} />
        <FBScientificActivity locale={locale} />
      </main>
      <Footer client:visible locale={locale} />
    </div>
  </div>
</Layout>
