---
import Layout from "@/layouts/Layout.astro";
import { Header } from "@/components/layout/Header";
import { MICHeroWithAbout } from "@/routes/departments/math-computing/sections/MICHeroWithAbout";
import { MICEducationalPrograms } from "@/routes/departments/math-computing/sections/MICEducationalPrograms";
import { MICDegreePrograms } from "@/routes/departments/math-computing/sections/MICDegreePrograms";
import { MICLeadership } from "@/routes/departments/math-computing/sections/MICLeadership";
import { MICScientificActivity } from "@/routes/departments/math-computing/sections/MICScientificActivity";
import { Footer } from "@/components/layout/Footer";
---

<Layout
  title="Кафедра математики та інтелектуальних обчислень | НаУОА"
  description="Кафедра математики та інтелектуальних обчислень — підготовка фахівців у сфері прикладної математики, математичного моделювання та інтелектуальних обчислювальних систем."
  ogImage="/images/Departments/dmc-hero.webp"
>
  <div
    class="overflow-hidden w-full min-h-screen flex justify-center bg-layout-bg"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header client:load headerPosition="absolute" />
      <main id="main-content" class="w-full">
        <MICHeroWithAbout client:load />
        <div
          class="relative w-full translate-y-[-1rem] animate-fade-in opacity-0 [--animation-delay:600ms]"
        >
          <MICEducationalPrograms />
        </div>
        <MICDegreePrograms client:visible />
        <MICLeadership />
        <MICScientificActivity />
      </main>
      <Footer client:visible />
    </div>
  </div>
</Layout>
