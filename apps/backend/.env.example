# ─── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Vector DB ────────────────────────────────────────────────────────────────
# For local Docker: use "localhost"
# For Qdrant Cloud: use "your-cluster-id.europe-west3-0.gcp.cloud.qdrant.io"
QDRANT_URL=localhost
QDRANT_API_KEY=

# ─── Analytics DB ─────────────────────────────────────────────────────────────
DB_PATH=./data/analytics.db

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000

# ─── Security ─────────────────────────────────────────────────────────────────
# Legacy admin API token (still works alongside OAuth)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Max chat requests per 5 minutes per IP (default: 10)
RATE_LIMIT_PER_MIN=10

# ─── Logging ──────────────────────────────────────────────────────────────────
# Set to "debug" for verbose output (default: info)
LOG_LEVEL=info

# ─── Phase 2: Google OAuth ────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/admin/auth/callback

# JWT secret for admin session tokens (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of allowed Google emails for admin access
# Leave empty to allow any authenticated Google user
ADMIN_ALLOWED_EMAILS=

# ─── Phase 3: Upstash Redis (Caching) ────────────────────────────────────────
# Get from: console.upstash.com → Redis → REST API
# Leave empty to disable caching (system works fine without it)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Phase 3: Feature Flags ──────────────────────────────────────────────────
# Enable Gemini-based reranking of search results (adds ~200ms latency)
ENABLE_RERANKING=false
