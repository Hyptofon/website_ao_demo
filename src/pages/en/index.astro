---
import Layout from "@/layouts/Layout.astro";
import { Header } from "@/components/layout/Header";
import { HeroWithAbout } from "@/routes/home/sections/HeroWithAbout";
import { EducationalPrograms } from "@/routes/home/sections/EducationalPrograms";
import { Departments } from "@/routes/home/sections/Departments";
import { InstituteLeadership } from "@/routes/home/sections/InstituteLeadership";
import { InnovativeEducation } from "@/routes/home/sections/InnovativeEducation";
import { NewsAndEvents } from "@/routes/home/sections/NewsAndEvents";
import { Footer } from "@/components/layout/Footer";
import { LazyIntroAnimation } from "@/components/effects/LazyIntroAnimation";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n";
import { getDepartments } from "@/routes/departments/departments-programs";

const locale: Locale = "en";
const t = getTranslations(locale);
const siteUrl = Astro.site?.toString()?.replace(/\/$/, "") ?? Astro.url.origin;

const coursesJsonLd = getDepartments(t).flatMap((dept) =>
  dept.programs.flatMap((level) =>
    level.programs.map((prog) => ({
      "@type": "Course",
      name: `${prog.label} ${prog.title}`,
      description: `${level.title} — ${dept.title}`,
      provider: {
        "@type": "EducationalOrganization",
        name: t.jsonLd.name,
        url: siteUrl,
      },
      ...(prog.link ? { url: prog.link } : {}),
    }))
  )
);

const organizationJsonLd = {
  "@type": "EducationalOrganization",
  name: t.jsonLd.name,
  alternateName: t.jsonLd.alternateName,
  description: t.jsonLd.description,
  url: siteUrl,
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: t.jsonLd.parentOrgName,
    url: "https://www.oa.edu.ua",
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: t.jsonLd.streetAddress,
    addressLocality: t.jsonLd.city,
    postalCode: "35800",
    addressCountry: "UA",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+380678792526",
    email: "press@oa.edu.ua",
    contactType: "main",
  },
};
---

<Layout
  title={t.meta.homeTitle}
  description={t.meta.homeDescription}
  locale={locale}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [organizationJsonLd, ...coursesJsonLd],
    })}
  />
  <!-- First-visit intro animation (typewriter effect) -->
  <LazyIntroAnimation client:load locale={locale} />

  <div
    class="overflow-hidden w-full min-h-screen flex justify-center bg-layout-bg"
  >
    <div class="flex w-full relative flex-col items-start min-h-screen">
      <Header
        client:load
        headerPosition="absolute"
        locale={locale}
        currentPath={Astro.url.pathname}
      />
      <main id="main-content" class="w-full">
        <HeroWithAbout client:load locale={locale} />
        <section class="relative w-full">
          <EducationalPrograms client:visible locale={locale} />
        </section>
        <section class="relative w-full">
          <Departments client:visible locale={locale} />
        </section>
        <InstituteLeadership client:visible locale={locale} />
        <InnovativeEducation client:visible locale={locale} />
        <NewsAndEvents client:visible locale={locale} />
        <Footer client:visible locale={locale} />
      </main>
    </div>
  </div>
</Layout>
