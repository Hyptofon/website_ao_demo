---
import "../styles/global.css";
import { CursorEffects } from "@/components/effects/CursorEffects";
import {
  DEFAULT_LOCALE,
  OG_LOCALES,
  getAlternatePath,
  getTranslations,
} from "@/i18n";
import type { Locale } from "@/i18n";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  canonicalUrl?: string;
  locale?: Locale;
  jsonLdExtra?: Record<string, unknown>;
}

const locale = (Astro.props.locale ?? DEFAULT_LOCALE) as Locale;
const t = getTranslations(locale);

const {
  title = t.meta.defaultTitle,
  description = t.meta.defaultDescription,
  ogImage = "/images/Home/og-default.webp",
  ogType = "website",
  canonicalUrl,
  jsonLdExtra,
} = Astro.props;

const siteUrl = Astro.site?.toString()?.replace(/\/$/, "") ?? "";
const metadataBaseUrl = siteUrl || Astro.url.origin;
const toAbsoluteUrl = (value: string): string =>
  new URL(value, `${metadataBaseUrl}/`).toString();
const currentUrl = toAbsoluteUrl(canonicalUrl ?? Astro.url.pathname);
const ogImageUrl = toAbsoluteUrl(ogImage);
const alternateLang = locale === "uk" ? "en" : "uk";
const alternateUrl = toAbsoluteUrl(
  getAlternatePath(Astro.url.pathname, alternateLang),
);
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1215" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300..900;1,300..900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300..900;1,300..900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300..900;1,300..900&display=swap"
      />
    </noscript>
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    <link rel="alternate" hreflang={locale} href={currentUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={locale === "uk" ? currentUrl : alternateUrl}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={OG_LOCALES[locale]} />
    <meta property="og:locale:alternate" content={OG_LOCALES[alternateLang]} />
    <meta property="og:site_name" content={t.meta.siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        name: t.jsonLd.name,
        alternateName: t.jsonLd.alternateName,
        url: siteUrl,
        logo: `${siteUrl}/favicon.svg`,
        description: t.jsonLd.description,
        address: {
          "@type": "PostalAddress",
          streetAddress: t.jsonLd.streetAddress,
          addressLocality: t.jsonLd.city,
          postalCode: "35800",
          addressCountry: "UA",
        },
        telephone: "+380678792526",
        email: "press@oa.edu.ua",
        parentOrganization: {
          "@type": "CollegeOrUniversity",
          name: t.jsonLd.parentOrgName,
          url: "https://www.oa.edu.ua",
        },
      })}
    />

    {jsonLdExtra && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLdExtra)}
      />
    )}

    <script is:inline>
      /* Check intro state instantly before body parses to prevent flash */
      if (typeof window !== "undefined") {
        try {
          var isHome = window.location.pathname === "/" || window.location.pathname === "/en/";
          if (isHome && !localStorage.getItem("itb_intro_seen")) {
            document.documentElement.classList.add("intro-active");
          }
        } catch (e) {}
      }
    </script>
  </head>
  <body class="antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[200] focus:top-4 focus:left-4 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:font-medium"
      >{t.common.skipToContent}</a
    >
    <div id="site-wrapper">
      <slot />
    </div>
    <CursorEffects client:idle />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    overflow-x: hidden;
  }

  body {
    background: var(--color-layout-bg);
  }

  /* Wow Appearance Animation Variables & Rules */
  html.intro-active body {
    background-color: #030712 !important; /* matches IntroAnimation */
    overflow: hidden;
  }
  html.intro-active #site-wrapper {
    opacity: 0;
    transform: scale(0.95) translateY(20px);
    filter: blur(10px);
    pointer-events: none;
  }

  html.intro-transitioning body {
    background-color: var(--color-layout-bg) !important;
    transition: background-color 1.5s ease-in-out;
    overflow: hidden;
  }
  html.intro-transitioning #site-wrapper {
    opacity: 1;
    transform: scale(1) translateY(0);
    filter: blur(0);
    pointer-events: auto;
    transition:
      opacity 1.5s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.5s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.1s; /* Start alongside IntroAnimation fade */
  }
</style>
